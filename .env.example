NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
# ⚠️  Utiliser le Transaction Pooler (port 5432) pour les environnements serverless (Vercel, etc.)
#     L'URL directe ne fonctionnera pas sur Vercel → ENOTFOUND
SUPABASE_DB_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres

# Vercel Blob (optional, for product images)
BLOB_READ_WRITE_TOKEN=xxx

# Scripts (optional)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=changeme

# Cron (optional)
CRON_SECRET=xxx
