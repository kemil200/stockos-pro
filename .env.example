NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
# ⚠️  Utiliser le Session Pooler (port 6543) pour les environnements serverless (Vercel, etc.)
#     L'URL directe (port 5432) ne fonctionnera pas sur Vercel → ENOTFOUND
SUPABASE_DB_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Vercel Blob (optional, for product images)
BLOB_READ_WRITE_TOKEN=xxx

# Cron (optional)
CRON_SECRET=xxx
